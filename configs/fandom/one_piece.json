{
    "series": "One Piece",
    "base_url": "https://onepiece.fandom.com",
    "episode_path": "/wiki/Episode_{episode}",
    "selectors": {
        "title": ".pi-theme-Episode .pi-title",
        "chapter": "div[data-source='chapter'] .pi-data-value",
        "arc": ".pt-page-level-tracker__accordion-title"
    },
    "chapter_metadata": {
        "index_path": "/wiki/Chapters_and_Volumes",
        "url_strategy": "numbered",
        "chapter_path": "/wiki/Chapter_{chapter}"
    },
    "chapter_selectors": {
        "title": null,
        "manga_arc": "a[title^='Category:'][title$=' Arc Chapters']",
        "title_strategy": "one_piece_title_sentence",
        "arc_strategy": "one_piece_arc_category"
    },
    "scraper": {
        "max_episodes": 5,
        "start_episode": null,
        "end_episode": null,
        "full_crawl": false,
        "config_path": "configs/fandom/one_piece.json"
    }
}