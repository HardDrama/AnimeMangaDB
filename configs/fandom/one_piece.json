{
    "series": "One Piece",
    "base_url": "https://onepiece.fandom.com",
    "episode_path": "/wiki/Episode_{episode}",
    "selectors": {
        "title": ".pi-theme-Episode .pi-title",
        "chapter": "div[data-source='chapter'] .pi-data-value",
        "arc": ".pt-page-level-tracker__accordion-title"
    },
    "chapter_metadata": {
